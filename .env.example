# QuantTerm Environment Configuration Template
# Copy this file to .env and fill in your values

# Application
APP_NAME=QuantTerm
APP_VERSION=0.1.0
DEBUG=false

# Paths (optional - defaults will be used if not set)
# DATA_DIR=/path/to/data
# CACHE_DIR=/path/to/cache
# LOG_DIR=/path/to/logs

# Data Provider API Keys
# Bloomberg API (institutional)
# BLOOMBERG_API_KEY=your_bloomberg_key

# Refinitiv Eikon
# REFINITIV_API_KEY=your_refinitiv_key

# Polygon.io
# POLYGON_API_KEY=your_polygon_key

# Alpaca Markets
# ALPACA_KEY=your_alpaca_key
# ALPACA_SECRET=your_alpaca_secret

# Federal Reserve Economic Data
# FRED_API_KEY=your_fred_key

# Database Connections
REDIS_URL=redis://localhost:6379/0
# POSTGRES_URL=postgresql://user:pass@localhost:5432/quantterm
# TIMESCALEDB_URL=postgresql://user:pass@localhost:5432/timeseries

# Risk Parameters
DEFAULT_VAR_CONFIDENCE=0.99
DEFAULT_VAR_HORIZON=1
DEFAULT_RISK_FREE_RATE=0.05

# Calculation Settings
MC_SIMULATIONS=100000
NUMBA_ENABLED=true
PARALLEL_WORKERS=4

# Trading Parameters
DEFAULT_COMMISSION=0.001
DEFAULT_SLIPPAGE=0.0005

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
